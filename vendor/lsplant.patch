-        axisZoom: true, //zoom axis when mouse over it is allowed
-        plotZoom: true, //zoom axis is allowed for plot zoom
-        axisPan: true, //pan axis when mouse over it is allowed
-        plotPan: true //pan axis is allowed for plot pan
-    }
