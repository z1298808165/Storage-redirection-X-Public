-    inline char* GenerateDigits(char buf[16], unsigned val, unsigned maxval) {
-        assert(val <= maxval);
-        constexpr unsigned kBase = 64;  // avoid integer division.
-        unsigned p = 15;
-        buf[p--] = 0;
-        while (maxval > 0) {
-            buf[p--] = ' ' + (val % kBase);
-            val /= kBase;
-            maxval /= kBase;
-        }
-        return buf + p + 1;
-    }
