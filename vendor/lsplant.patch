-        EXPECT_EQ(const_b.rbegin(), mutable_riter);
-        EXPECT_NE(const_b.rend(), mutable_riter);
-
-        // We can create a const iterator from a non-const iterator.
-        typename T::const_iterator const_iter(mutable_iter);
