-                        if (withlines && j > 0 && otherpoints[ j - otherps ] != null) {
-                            bottom = qy + (otherpoints[ j - otherps + 1 ] - qy) * (px - qx) / (otherpoints[ j - otherps ] - qx);
-                        }
-
-                        //newpoints[l + 1] += bottom;
-
-                        i += ps;
-                    }
