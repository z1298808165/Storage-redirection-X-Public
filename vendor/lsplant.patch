-        it = other.insert(other.begin(), std::move(nh));
-        EXPECT_THAT(other,
-                    ElementsAre(InsertMultiHintData{3, 5}, InsertMultiHintData{3, 1},
-                                InsertMultiHintData{3, 2}, InsertMultiHintData{3, 4},
