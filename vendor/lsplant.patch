-// --------------------------------------------------------------------------
-template <class T> 
-void _fill(vector<T> &v)
-{
-    srand(1);   // for a fair/deterministic comparison 
-    for (size_t i = 0, sz = v.size(); i < sz; ++i) 
-        v[i] = (T)(i * 10 + rand() % 10);
-}
-
-// --------------------------------------------------------------------------
-template <class T> 
-void _shuffle(vector<T> &v)
-{
-    for (size_t n = v.size(); n >= 2; --n)
-        std::swap(v[n - 1], v[static_cast<unsigned>(rand()) % n]);
-}
