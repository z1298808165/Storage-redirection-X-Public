-// --------------------------------------------------------------------------
-char * new_string_from_integer(uint64_t num)
-{
-    int ndigits = num == 0 ? 1 : (int)log10(num) + 1;
-    char * str = (char *)malloc(ndigits + 1);
-    sprintf(str, "%u", (unsigned int)num);
-    return str;
-}
