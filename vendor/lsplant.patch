-// convert positive number from string to uint32_t
-inline uint32_t fast_atoll64(const char* str)
-{
-   uint32_t val  = 0;
-   uint8_t digit;
-   while ((digit = uint8_t(*str++ - '0')) <= 9)
-      val = val * 10 + digit;
-   return val;
-}
